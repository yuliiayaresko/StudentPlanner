@model StudetPlanner.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["FullWidth"] = true;

    string GetSubjectColor(int? id)
    {
        var colors = new[] { "#ff4fd8", "#3b82f6", "#8b5cf6", "#10b981", "#f59e0b" };
        return colors[(id ?? 0) % colors.Length];
    }

    var today = DateTime.Today;
    var weekStart = today.AddDays(-(((int)today.DayOfWeek + 6) % 7));

    var hour = DateTime.Now.Hour;
    string greeting = hour < 12 ? "Доброго ранку" : hour < 18 ? "Добрий день" : "Добрий вечір";
    var userName = User.Identity?.Name ?? "";
    var shortName = userName.Contains('@') ? userName.Split('@')[0] : userName;
    var todayTaskCount = Model.Tasks.Count(t =>
        (t.Deadline.HasValue ? t.Deadline.Value.ToString("yyyy-MM-dd") : t.CreatedAt.ToString("yyyy-MM-dd"))
        == today.ToString("yyyy-MM-dd"));
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var tokens = Antiforgery.GetAndStoreTokens(Context);
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="dashboard-wrapper">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <!-- TODAY'S FOCUS (replaces Inbox button) -->
        <div class="today-focus-block">
            <div class="today-focus-greeting">@greeting, @shortName</div>
            <div class="today-focus-date">@today.ToString("dddd, d MMMM", new System.Globalization.CultureInfo("uk-UA"))</div>
            <div class="today-focus-stat">
                @if (todayTaskCount == 0)
                {
                    <span>Сьогодні задач немає</span>
                }
                else
                {
                    <span>@todayTaskCount задач@(todayTaskCount == 1 ? "а" : todayTaskCount < 5 ? "и" : "") сьогодні</span>
                }
            </div>
        </div>

        <div class="quick-add-wrapper">
            <input id="quick-task" type="text" placeholder="Швидко додати задачу..." />
            <button onclick="quickAdd()">＋</button>
        </div>

        <h6 class="text-white mb-1" style="font-size:0.82rem;">МОЇ ПРЕДМЕТИ</h6>
        <p style="color:#555;font-size:0.73rem;margin-bottom:0.6rem;">Університетські курси</p>

        <div id="subject-list-sidebar">
            @foreach (var s in Model.Subjects)
            {
                <a class="subject-link" href="javascript:void(0)" data-subject-id="@s.Id"
                   onclick="openSubjectPanel(@s.Id)">
                    <div class="subject-dot" style="background:@GetSubjectColor(s.Id)"></div>
                    <span>@s.Name</span>
                </a>
            }
            @if (!Model.Subjects.Any())
            {
                <p style="color:#444;font-size:0.8rem;margin-top:0.4rem;">Ще немає предметів</p>
            }
        </div>

        <button class="add-subject-btn" onclick="openSubjectModal()">＋ Додати предмет</button>
    </aside>

    <!-- MAIN -->
    <div class="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <h4 id="period-label">@today.ToString("MMMM yyyy")</h4>
                <div class="d-flex gap-1">
                    <button class="view-btn active" onclick="switchView('day',this)">День</button>
                    <button class="view-btn" onclick="switchView('multiday',this)">3 дні</button>
                    <button class="view-btn" onclick="switchView('week',this)">Тиждень</button>
                    <button class="view-btn" onclick="switchView('month',this)">Місяць</button>
                </div>
            </div>
            <div class="day-strip" id="day-strip">
                @for (int i = 0; i < 7; i++)
                {
                    var d = weekStart.AddDays(i);
                    <div class="day-item @(d.Date == today ? "active" : "")"
                         data-date="@d.ToString("yyyy-MM-dd")"
                         onclick="selectDay('@d.ToString("yyyy-MM-dd")', this)">
                        <small>@d.ToString("ddd")</small>@d.Day
                    </div>
                }
            </div>
        </div>

        <div class="content-area">
            <div id="view-day"></div>
            <div id="view-multiday" style="display:none;"></div>
            <div id="view-week" style="display:none;"></div>
            <div id="view-month" style="display:none;"></div>
        </div>
    </div>
</div>

<input type="hidden" name="__RequestVerificationToken" value="@tokens.RequestToken" />

<script>
    window.DASHBOARD_DATA = {
        tasks: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
          Model.Tasks.Select(t => new
          {
              id = t.Id,
              title = t.Title,
              description = t.Description,
              subjectName = t.Subject != null ? t.Subject.Name : null,
              subjectId = t.SubjectId,
              deadline = t.Deadline.HasValue ? t.Deadline.Value.ToString("yyyy-MM-ddTHH:mm") : (string?)null,
              createdAt = t.CreatedAt.ToString("yyyy-MM-ddTHH:mm"),
              status = t.Status,
              priority = t.Priority
          })
        )),
        subjects: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
            Model.Subjects.Select(s => new { id = s.Id, name = s.Name })
        )),
        antiForgery: "@tokens.RequestToken"
    };
</script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>
