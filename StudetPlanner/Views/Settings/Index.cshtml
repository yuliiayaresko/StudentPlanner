@model StudetPlanner.Models.User
@{
    ViewData["Title"] = "Налаштування";
    ViewData["FullWidth"] = true;
    var connected = !string.IsNullOrEmpty(Model.TelegramChatId);
}

<style>
    .settings-wrap {
        max-width: 560px;
        margin: 2.5rem auto;
        padding: 0 1rem;
    }

    .settings-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }

    .settings-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid #e5e5ea;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1rem;
    }

    .settings-card-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1rem;
    }

    .tg-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: linear-gradient(135deg, #29b6f6, #0288d1);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .tg-icon svg {
            width: 22px;
            height: 22px;
            fill: white;
        }

    .settings-card-title {
        font-size: 1rem;
        font-weight: 600;
        color: #1a1a1a;
        margin: 0;
    }

    .settings-card-sub {
        font-size: 0.8rem;
        color: #8a8a8e;
        margin: 0;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.78rem;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .status-badge.connected {
        background: #d1fae5;
        color: #065f46;
    }

    .status-badge.disconnected {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .connected .status-dot { background: #10b981; }
    .disconnected .status-dot { background: #9ca3af; }

    .divider {
        border: none;
        border-top: 1px solid #f0f0f5;
        margin: 1rem 0;
    }

    .code-box {
        background: #f9f9fb;
        border: 1px solid #e5e5ea;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .code-number {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 6px;
        color: #1a1a1a;
        font-variant-numeric: tabular-nums;
    }

    .code-expires {
        font-size: 0.75rem;
        color: #8a8a8e;
        margin-top: 2px;
    }

    .btn-tg-primary {
        background: linear-gradient(135deg, #29b6f6, #0288d1);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
        white-space: nowrap;
    }

        .btn-tg-primary:hover { opacity: 0.85; color: white; }

    .btn-tg-danger {
        background: transparent;
        color: #ef4444;
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: 10px;
        padding: 8px 18px;
        font-size: 0.85rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
    }

        .btn-tg-danger:hover {
            background: rgba(239,68,68,0.08);
            border-color: rgba(239,68,68,0.5);
        }

    .toggle-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .toggle-label {
        font-size: 0.88rem;
        color: #3a3a3a;
    }

    .toggle-sub {
        font-size: 0.76rem;
        color: #8a8a8e;
        margin-top: 1px;
    }

    .form-switch .form-check-input {
        width: 2.5em;
        height: 1.3em;
        cursor: pointer;
    }

        .form-switch .form-check-input:checked {
            background-color: #8b5cf6;
            border-color: #8b5cf6;
        }

    .how-to {
        background: #f0f9ff;
        border: 1px solid #bae6fd;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        font-size: 0.82rem;
        color: #0369a1;
        line-height: 1.6;
    }

        .how-to ol {
            margin: 0.5rem 0 0 0;
            padding-left: 1.2rem;
        }

    .alert-info-soft {
        background: #faf5ff;
        border: 1px solid #e9d5ff;
        border-radius: 12px;
        padding: 0.85rem 1.1rem;
        font-size: 0.82rem;
        color: #6d28d9;
    }
</style>

<div class="settings-wrap">
    <div class="settings-title">Налаштування</div>

    <!-- TELEGRAM CARD -->
    <div class="settings-card">
        <div class="settings-card-header">
            <div class="tg-icon">
                <svg viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.17 13.5l-2.95-.924c-.64-.203-.654-.64.136-.954l11.52-4.446c.532-.194 1.01.13.818.95z"/></svg>
            </div>
            <div>
                <p class="settings-card-title">Telegram-сповіщення</p>
                <p class="settings-card-sub">Нагадування про дедлайни прямо у Telegram</p>
            </div>
            <div class="ms-auto">
                <span class="status-badge @(connected ? "connected" : "disconnected")">
                    <span class="status-dot"></span>
                    @(connected ? "Підключено" : "Не підключено")
                </span>
            </div>
        </div>

        @if (!connected)
        {
            <!-- НЕ ПІДКЛЮЧЕНО -->
            <div class="how-to mb-3">
                <strong>Як підключити:</strong>
                <ol>
                    <li>Натисни «Отримати код» нижче</li>
                    <li>Відкрий бота у Telegram і надішли йому цей код</li>
                    <li>Готово — бот підтвердить підключення</li>
                </ol>
            </div>

            <div id="codeSection" style="display:none;" class="mb-3">
                <div class="code-box">
                    <div>
                        <div class="code-number" id="codeValue">—</div>
                        <div class="code-expires" id="codeExpiry"></div>
                    </div>
                    <a id="openBotBtn" href="#" target="_blank" class="btn-tg-primary text-decoration-none">
                        Відкрити бота →
                    </a>
                </div>
            </div>

            <button class="btn-tg-primary" id="generateBtn" onclick="generateCode()">
                Отримати код
            </button>
        }
        else
        {
            <!-- ПІДКЛЮЧЕНО -->
            <hr class="divider" />

            <div class="toggle-row mb-3">
                <div>
                    <div class="toggle-label">Надсилати нагадування</div>
                    <div class="toggle-sub">За 24 год., за 3 год. до дедлайну та при простроченні</div>
                </div>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="notifToggle"
                           @(Model.TelegramNotifications ? "checked" : "")
                           onchange="toggleNotifications(this)" />
                </div>
            </div>

            <div class="alert-info-soft mb-3">
                ✅ Telegram підключено. Бот надсилатиме сповіщення автоматично для задач з дедлайном.
            </div>

            <button class="btn-tg-danger" onclick="disconnectTelegram()">
                Відключити Telegram
            </button>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
    async function generateCode() {
        const btn = document.getElementById('generateBtn');
        btn.disabled = true;
        btn.textContent = 'Генерую...';

        const res = await fetch('/Settings/GenerateTelegramCode', { method: 'POST', headers: { 'RequestVerificationToken': getAntiForgery() } });
        const data = await res.json();

        document.getElementById('codeValue').textContent = data.code;
        document.getElementById('codeExpiry').textContent = 'Дійсний до ' + data.expiresAt + ' (10 хв)';
        document.getElementById('codeSection').style.display = 'block';
        document.getElementById('openBotBtn').href = 'https://t.me/studenttplanner_bot';

        btn.textContent = 'Оновити код';
        btn.disabled = false;

        // Автоперевірка підключення кожні 5 сек
        const check = setInterval(async () => {
            const r = await fetch('/Settings/GetTelegramStatus');
            const s = await r.json();
            if (s.connected) { clearInterval(check); location.reload(); }
        }, 5000);
    }

    async function toggleNotifications(el) {
        const res = await fetch('/Settings/ToggleNotifications', { method: 'POST', headers: { 'RequestVerificationToken': getAntiForgery() } });
        const data = await res.json();
        el.checked = data.enabled;
    }

    async function disconnectTelegram() {
        if (!confirm('Відключити Telegram? Ти більше не отримуватимеш сповіщення.')) return;
        await fetch('/Settings/DisconnectTelegram', { method: 'POST', headers: { 'RequestVerificationToken': getAntiForgery() } });
        location.reload();
    }

    function getAntiForgery() {
        return document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
    }
</script>
}
