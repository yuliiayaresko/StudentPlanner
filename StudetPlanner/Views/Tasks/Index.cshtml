@model IEnumerable<StudetPlanner.Models.TaskItem>

@{
    ViewData["Title"] = "Задачі";
}

<section class="planner-header">
    <h1 class="planner-title">Мої задачі</h1>
</section>

<section class="timeline">
    @{
        var hasTasks = false;
        var priorityLabels = new[] { "Звичайний", "Важливо" };
        var statusLabels = new[] { "Не розпочато", "В процесі", "Зроблено" };
    }
    @foreach (var item in Model)
    {
        hasTasks = true;
        <article class="timeline-item">
            <div class="timeline-time">
                @(item.Deadline?.ToString("HH:mm") ?? "--:--")
            </div>
            <div class="task-card">
                <div class="task-card__title">@item.Title</div>
                <div class="task-card__meta">
                    @(item.Deadline?.ToString("dd MMM yyyy") ?? "Без дедлайну") &bull;
                    @(priorityLabels[item.Priority]) &bull;
                    @(statusLabels[item.Status])
                </div>
                <div class="task-card__actions">
                    <a asp-action="Details" asp-route-id="@item.Id">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
                </div>
            </div>
        </article>
    }
    @if (!hasTasks)
    {
        <div class="task-card">
            <div class="task-card__title">Задач ще немає</div>
            <div class="task-card__meta">Натисни + щоб створити першу задачу.</div>
        </div>
    }
</section>

<a class="fab-create-task" asp-action="Create" aria-label="Створити задачу">+</a>
