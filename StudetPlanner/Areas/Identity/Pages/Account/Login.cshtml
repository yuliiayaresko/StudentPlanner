@page
@model LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>Вхід — Student Planner</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>

    <div class="container">

        <div class="left">
            <img src="/images/bg.jpg" alt="bg" />
        </div>

        <div class="right">
            <div class="form-box">

                <h1>Ласкаво просимо до</h1>
                <h2>Student Planner</h2>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="error"></div>

                    <input asp-for="Input.Email" placeholder="Ваша email адреса" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="error"></span>

                    <input asp-for="Input.Password" type="password" placeholder="Пароль" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="error"></span>

                    <button type="submit">Увійти</button>
                </form>

                <p class="register">
                    Ще немає акаунту?
                    <a asp-page="./Register">Зареєструватись</a>
                </p>

            </div>
        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</body>
</html>
