@page
@model RegisterModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>Реєстрація — Student Planner</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>

    <div class="container">

        <div class="left">
            <img src="/images/bg.jpg" alt="bg" />
        </div>

        <div class="right">
            <div class="form-box">

                <h1>Долучись до</h1>
                <h2>Student Planner</h2>

                <form id="registerForm" method="post">

                    <div asp-validation-summary="ModelOnly" class="error"></div>

                    <input asp-for="Input.Email" placeholder="Ваша email адреса" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="error"></span>

                    <input asp-for="Input.Password" type="password" placeholder="Пароль" autocomplete="new-password" />
                    <span asp-validation-for="Input.Password" class="error"></span>

                    <input asp-for="Input.ConfirmPassword" type="password" placeholder="Підтвердіть пароль" autocomplete="new-password" />
                    <span asp-validation-for="Input.ConfirmPassword" class="error"></span>

                    <button type="submit">Створити акаунт</button>

                </form>

                <p class="register">
                    Вже є акаунт?
                    <a asp-page="./Login">Увійти</a>
                </p>

            </div>
        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</body>
</html>
